{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": { "@shared/*": ["shared/*"] }
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "shared/**/*.ts",
    "electron.vite.config.ts",
    "tests/e2e/**/*.ts",
    "tests/fixtures/**/*.ts",
    "playwright.config.ts",
    "vitest.config.ts"
  ]
}
